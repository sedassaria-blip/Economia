import discord
from discord.ext import commands
from discord import app_commands

bot = commands.Bot(command_prefix="!", intents=discord.Intents.default())

economia = {}


class RetirarModal(discord.ui.Modal, title="Retirar Dinheiro"):
    valor = discord.ui.TextInput(label="Valor")

    async def on_submit(self, interaction: discord.Interaction):
        user = str(interaction.user.id)
        valor = int(self.valor.value)

        if economia[user]["banco"] < valor:
            return await interaction.response.send_message(
                "❌ Você não possui esse valor no banco.",
                ephemeral=True
            )

        economia[user]["banco"] -= valor
        economia[user]["saldo"] += valor

        await interaction.response.send_message(
            f"✅ Você retirou {valor} moedas.",
            ephemeral=True
        )


