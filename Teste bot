@bot.tree.command(name="banco", description="Veja seu banco")
async def banco(interaction: discord.Interaction):

    user = str(interaction.user.id)

    if user not in economia:
        economia[user] = {
            "saldo": 1112,
            "banco": 223
        }

    embed = discord.Embed(
        title="🏦 Banco",
        color=discord.Color.blue()
    )

    embed.add_field(
        name="💰 Saldo em dinheiro",
        value=economia[user]["saldo"],
        inline=False
    )

    embed.add_field(
        name="🏦 Saldo bancário",
        value=economia[user]["banco"],
        inline=False
    )

    embed.add_field(
        name="📋 Ações",
        value="Deseja fazer um depósito, uma transferência ou um saque?",
        inline=False
    )

    await interaction.response.send_message(
        embed=embed,
        view=BancoView()
    )

