    @discord.ui.button(label="Depositar", emoji="➕", style=discord.ButtonStyle.success)
    async def depositar(self, interaction: discord.Interaction, button: discord.ui.Button):
        await interaction.response.send_message(
            "💰 Use o comando de depósito do seu sistema.",
            ephemeral=True
        )

    @discord.ui.button(label="Retirar", emoji="➖", style=discord.ButtonStyle.danger)
    async def retirar(self, interaction: discord.Interaction, button: discord.ui.Button):
        await interaction.response.send_modal(RetirarModal())

    @discord.ui.button(label="Transferir", emoji="🔄", style=discord.ButtonStyle.primary)
    async def transferir(self, interaction: discord.Interaction, button: discord.ui.Button):
